# .shellcheckrc — project-wide shellcheck configuration
# SC1090: Can't follow non-constant source — expected for our plugin architecture
# SC2034: Variable appears unused — lang_name/lang_cmd are used by the sourcing script
# SC2154: Variable referenced but not assigned — engine globals set by engine_init,
#         lang vars set by source'd adapters
disable=SC1090,SC2034,SC2154
